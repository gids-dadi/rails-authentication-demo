<div class="container">
  <h5>Roles List</h5>

  <table class="table table-striped" style="width:70%">
    <thead>
      <tr>
        <th>Role Name</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @roles.each do |role| %>
        <tr>
          <td><%= role.name %></td>
          
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<p>
  <%= link_to "New Role", new_role_path, class: "btn btn-primary" %>
  <%= link_to "Back to Dashboard", dashboard_index_path, class: "btn btn-secondary" %>
</p>
