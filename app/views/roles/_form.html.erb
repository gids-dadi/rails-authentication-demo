<%= form_for role do |f| %>
  <div class="container">
    <h5>Role Form</h5>

    <!-- Role Name -->
    <div class="mb-2">
      <span>Role Name: </span>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <!-- Submit -->
    <div class="mb-2">
      <%= f.submit "Create Role", method: :post, class: "btn btn-primary" %>
    </div>
  </div>

  <div class="mb-2">
    <%= link_to "Back to Roles List", roles_path, class: "btn btn-secondary" %>
  </div>
  <% end %>