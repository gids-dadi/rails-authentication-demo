<div class="container">
  <h5>Update Profile</h5>
  
  <%= form_for :customer, url: manage_customer_path, method: :post do |f| %>
    <!-- Username -->
    <div class="mb-2">
      <span>Username: </span>
      <%= f.text_field :username, class: "form-control", value: current_admin.username, required: true %>
    </div>

    <!-- First Name -->
    <div class="mb-2">
      <span>First Name: </span>
      <%= f.text_field :first_name, class: "form-control", value: current_admin.first_name, required: true %>
    </div>

    <!-- Last Name -->
    <div class="mb-2">
      <span>Last Name: </span>
      <%= f.text_field :last_name, class: "form-control", value: current_admin.last_name, required: true %>
    </div>

    <!-- Email -->
    <div class="mb-2">
      <span>Email: </span>
      <%= f.email_field :email, class: "form-control", value: current_admin.email, required: true %>
    </div>

    <!-- Submit -->
    <div class="mb-2">
      <%= f.submit "Update Profile", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
