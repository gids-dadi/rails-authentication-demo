<div class="container">



  <% if admin_signed_in? && %>
    <h1 class="mt-4">Welcome to the Dashboard, <%= current_admin.username %>!</h1>
    <%= link_to "Update Password", edit_admin_registration_path, class: "btn btn-primary ml-4 mt-4" %>

    <%= link_to "Delete Account", registration_path(current_admin), 
          data: { 
            turbo_confirm: "Are you sure?",
            turbo_method: :delete, 
          
          }, 
          class: "btn btn-danger ml-4 mt-4" %>

    <%= link_to "Update Profile", edit_customer_path, class: "btn btn-primary ml-4 mt-4" %>
  <% end %>

      <% if admin_signed_in? %>
    <%= link_to "Manage Roles", roles_path, class: "btn btn-primary mt-4" %>
    <%end %>
</div>
