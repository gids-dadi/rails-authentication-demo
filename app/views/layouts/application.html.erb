<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Authenticationdemo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
  </head>

  <body>

    <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %> alert-dismissible flash-message" role="alert">
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      <%= value %>
    </div>
    <%end%>

    <nav class="navbar-light navbar bg-dark justify-content-between">
      <h5 class="navbar-brand margin-left text-primary">Authentication Demo <br />
        <%= link_to "Home", root_path%>
      </h5>

      <% if admin_signed_in? %>
      <a href="" class="navbar-brand margin-left">
        Welcome <%= current_admin.username %>
      </a>
         <%end%>

         <form  class="form-inline">
          <% if admin_signed_in? %>
    <%= link_to "Sign Out", destroy_admin_session_path, 
        class: "btn btn-outline-success my-2",
        data: { 
          turbo_method: :delete,
          turbo_confirm: "Are you sure you want to sign out?"
        } %>
  
          <% else %>
          <%= link_to "Sign In", new_admin_session_path, class: "btn btn-outline-success" %>
          <%= link_to "Sign Up", new_admin_registration_path, class: "btn btn-outline-success " %>
         </form>
          <% end %>
    </nav>

    <%= yield %>
  </body>
</html>
